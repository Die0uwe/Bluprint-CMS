{% extends 'layout.twig' %}
{% block content %}
<div style="max-width:420px;margin:3rem auto;">
  <div class="cf-card">
    <div class="cf-card-header">🔐 Inloggen</div>
    <div class="cf-card-body">
      {% if error is defined %}<div class="cf-alert cf-alert-error">{{ error }}</div>{% endif %}
      <form method="POST" action="/login">
        {{ csrf_field()|raw }}
        <div class="cf-form-group">
          <label class="cf-label">Gebruikersnaam of E-mail</label>
          <input class="cf-input" type="text" name="identifier" required autofocus>
        </div>
        <div class="cf-form-group">
          <label class="cf-label">Wachtwoord</label>
          <input class="cf-input" type="password" name="password" required>
        </div>
        <button type="submit" class="cf-btn" style="width:100%;justify-content:center;">Inloggen →</button>
      </form>
      <p style="text-align:center;margin-top:1rem;font-size:.85rem;color:var(--muted);">
        Nog geen account? <a href="/register">Registreren</a>
      </p>
    </div>
  </div>
</div>
{% endblock %}
