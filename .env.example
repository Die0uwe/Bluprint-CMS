# Community Fusion CMS — Environment variabelen
# Kopieer naar .env en vul in

APP_NAME="Community Fusion CMS"
APP_URL=http://localhost
APP_ENV=production
APP_DEBUG=false
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fusion_cms
DB_USER=root
DB_PASS=
DB_PREFIX=cf_

CACHE_DRIVER=file
SESSION_LIFETIME=7200

MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="Community Fusion"

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
